# ── LangSmith ──────────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=cloudRAG-offline
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com

# ── AWS ────────────────────────────────────────────────────
# If you have AWS CLI configured (aws configure), leave these empty.
# Otherwise fill them in.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# ── Deploy (only needed for deploy_image.py) ───────────────
ECR_REPOSITORY=cloudrag-dev
ECS_CLUSTER=cloudrag-dev
ECS_SERVICE=cloudrag-dev

# ── OpenSearch Serverless ──────────────────────────────────
# Only needed for run_upload.py (not for run_local.py)
OPENSEARCH_ENDPOINT=      # e.g. xxxx.eu-west-1.aoss.amazonaws.com (no https://)
OPENSEARCH_INDEX=cloudrag-docs

# ── OpenAI (for synthetic query generation) ─────────────
OPENAI_API_KEY=

COHERE_API_KEY=

# ── API Authentication ─────────────────────────────────────
# Secret key required in X-API-Key header for POST /query
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=